# --- Dependencies ---
node_modules/
client/node_modules/
server/node_modules/

# --- Build output ---
client/dist/
server/public/

# --- Environment files (may contain secrets) ---
.env
.env.local
.env.*.local
client/.env
client/.env.local
client/.env.*.local
# Production client env is safe (public Firebase keys only); but per your request
# we will NOT commit any .env.production/.env.example files. Deployment will use
# `.gcloudignore` to still upload `client/.env.production` for Cloud Run builds.

# --- Logs ---
*.log
npm-debug.log*

# --- OS / editor ---
.DS_Store
.idea/
.vscode/

# --- Secrets (never commit) ---
*.pem
*.key
serviceAccountKey.json

# User request: never commit env templates
**/.env.example
**/.env.production
