# --- Dependencies ---
node_modules/
client/node_modules/
server/node_modules/

# --- Build output ---
client/dist/
server/public/

# --- Environment files (may contain secrets) ---
.env
.env.local
.env.*.local
client/.env
client/.env.local
client/.env.*.local
# Production client env is safe (public Firebase keys only); keep committed if desired.
!client/.env.production
!client/.env.example
!.env.example

# --- Logs ---
*.log
npm-debug.log*

# --- OS / editor ---
.DS_Store
.idea/
.vscode/

# --- Secrets (never commit) ---
*.pem
*.key
serviceAccountKey.json

# User request: do not commit env templates
.env.example
client/.env.production

# User request: never commit env templates
**/.env.example
**/.env.production
